{
  "configurations": [
    {
      "name": "c-compiler",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "defines": [
        "__struct=struct",
        "__array(T)=T*",
        "__eqref=void*",
        "__cast(T,...)=(T){0}",
        "__struct_new(T,...)=(T){0}",
        "__array_new(T,...)=(__array(T)){0}",
        "__array_of(T,...)=(__array(T)){0}",
        "__ref_is_null(R)=((R)==0)",
        "__ref_eq(A,B)=((A)==(B))",
        "__ref_test(T,R)=((R),0)",
        "__ref_cast(T,R)=((R),(T*){0})",
        "__extends(P)=_Static_assert(sizeof(P)>=0,\"\")"
      ],
      "cStandard": "c23",
      "intelliSenseMode": "${default}"
    }
  ],
  "version": 4
}
