{
  "bin": true,
  "name": "sqlite",
  "description": "SQLite 3.53.1 amalgamation + shell — interactive SQL REPL",
  "compilerArgs": [
    "-DSQLITE_WASI",
    "-DSQLITE_THREADSAFE=0",
    "-DSQLITE_OMIT_LOAD_EXTENSION=1",
    "-DSQLITE_OMIT_WAL",
    "-DSQLITE_MAX_MMAP_SIZE=0",
    "-DSQLITE_DEFAULT_MEMSTATUS=0",
    "-DSQLITE_OMIT_DEPRECATED",
    "-DHAVE_USLEEP=1"
  ],
  "includes": ["."],
  "sources": [
    "sqlite3.c",
    "shell.c"
  ]
}
